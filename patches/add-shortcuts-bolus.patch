+        // Observe bolus intent requests from Shortcuts
+        bolusIntentObserver = UserDefaults.appGroup?.observe(\.intentExtensionBolusRequest, options: [.new], changeHandler: { [weak self] (defaults, change) in
+            guard let bolusRequest = change.newValue as? [String: Any],
+                  let bolusAmount = bolusRequest["bolusAmount"] as? Double,
+                  let timestamp = bolusRequest["timestamp"] as? TimeInterval,
+                  let appGroup = UserDefaults.appGroup else {
+                return
+            }
+
+            // Validate the request is not too old (5 minute timeout)
+            let requestDate = Date(timeIntervalSince1970: timestamp)
+            guard Date().timeIntervalSince(requestDate) < 300 else {
+                self?.logger.error("Bolus Intent: Request expired (older than 5 minutes)")
+                appGroup.intentExtensionBolusRequest = nil
+                return
+            }
+
+            let isExternalInsulin = bolusRequest["isExternalInsulin"] as? Bool ?? false
+            let insulinTypeString = bolusRequest["insulinType"] as? String
+            let insulinType = insulinTypeString.flatMap { InsulinType(rawValue: $0) }
+
+            self?.logger.default("Bolus Intent: Processing bolus request of %.1f units (external: %@)", bolusAmount, String(describing: isExternalInsulin))
+
+            if isExternalInsulin {
+                // Log as manually entered dose
+                self?.addManuallyEnteredDose(startDate: Date(), units: bolusAmount, insulinType: insulinType)
+            } else {
+                // Deliver via pump - post notification for DeviceDataManager to handle
+                NotificationCenter.default.post(name: .BolusIntentRequest, object: self, userInfo: [
+                    "bolusAmount": bolusAmount,
+                    "activationType": BolusActivationType.manualNoRecommendation
+                ])
+            }
+
+            // Clear the request
+            appGroup.intentExtensionBolusRequest = nil
+        })

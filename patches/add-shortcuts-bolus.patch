diff --git a/Loop/Loop Intent Extension/IntentHandler.swift b/Loop Intent Extension/IntentHandler.swift
index 20c293a0..d6f422cf 100644
--- a/Loop/Loop Intent Extension/IntentHandler.swift	
+++ b/Loop/Loop Intent Extension/IntentHandler.swift	
@@ -12,7 +12,55 @@ class IntentHandler: INExtension {
     override func handler(for intent: INIntent) -> Any {
         if intent is EnableOverridePresetIntent {
             return OverrideIntentHandler()
+        } else if intent is BolusIntent {
+            return BolusIntentHandler()
         }
         return self
     }
 }
+
+class BolusIntentHandler: NSObject, BolusIntentHandling {
+    lazy var defaults = UserDefaults(suiteName: Bundle.main.appGroupSuiteName)
+
+    func handle(intent: BolusIntent, completion: @escaping (BolusIntentResponse) -> Void) {
+        guard let defaults = self.defaults else {
+            completion(BolusIntentResponse(code: .failure, userActivity: nil))
+            return
+        }
+
+        let bolusAmount = intent.bolusAmount as? Double ?? 0
+        let isExternalInsulin = intent.isExternalInsulin?.boolValue ?? false
+        let insulinType = intent.insulinType
+
+        // Validate bolus amount is positive
+        guard bolusAmount > 0 else {
+            completion(BolusIntentResponse(code: .failure, userActivity: nil))
+            return
+        }
+
+        // Get max bolus from settings
+        let maxBolus = defaults.object(forKey: "com.loopkit.Loop.maxBolus") as? Double ?? 25.0
+
+        // Validate bolus doesn't exceed max
+        guard bolusAmount <= maxBolus else {
+            completion(BolusIntentResponse(code: .failure, userActivity: nil))
+            return
+        }
+
+        // Store the bolus request in UserDefaults for the main app to process
+        var bolusRequest: [String: Any] = [
+            "bolusAmount": bolusAmount,
+            "isExternalInsulin": isExternalInsulin,
+            "timestamp": Date().timeIntervalSince1970
+        ]
+
+        if let insulinType = insulinType {
+            bolusRequest["insulinType"] = insulinType
+        }
+
+        defaults.set(bolusRequest, forKey: "intentExtensionBolusRequest")
+
+        // Continue in app because the UserDefaults KVO doesn't work in the background
+        completion(BolusIntentResponse(code: .continueInApp, userActivity: nil))
+    }
+}

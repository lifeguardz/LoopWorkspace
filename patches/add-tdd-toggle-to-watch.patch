 Loop/Managers/WatchDataManager.swift                | 15 +++++++++-
 WatchApp Extension/Controllers/ChartHUDController.swift | 35 +++++++++++++++++++-
 WatchApp Extension/Controllers/HUDRowController.swift  | 15 ++++++++++
 WatchApp Extension/Extensions/WatchContext+WatchApp.swift |  7 +++++
 WatchApp Extension/Localizable.xcstrings               | 23 ++++++++++++++
 6 files changed, 79 insertions(+), 2 deletions(-)


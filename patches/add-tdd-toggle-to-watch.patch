diff --git a/Loop/Managers/WatchDataManager.swift b/Loop/Managers/WatchDataManager.swift
index 1234567..abcdefg 100644
--- a/Loop/Managers/WatchDataManager.swift
+++ b/Loop/Managers/WatchDataManager.swift
@@ -297,6 +297,19 @@ final class WatchDataManager: NSObject {
             }
             updateGroup.leave()
         }
+
+        // Fetch TDD for today
+        updateGroup.enter()
+        let startOfDay = Calendar.current.startOfDay(for: Date())
+        self.deviceManager.doseStore.getTotalUnitsDelivered(since: startOfDay) { (result) in
+            switch result {
+            case .success(let tddValue):
+                context.tdd = tddValue.value
+            case .failure:
+                context.tdd = nil
+            }
+            updateGroup.leave()
+        }
 
         _ = updateGroup.wait(timeout: .distantFuture)
 

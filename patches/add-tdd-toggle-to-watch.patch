@@ -165,7 +166,14 @@ final class ChartHUDController: HUDInterfaceController, WKCrownDelegate {
 
             switch row {
             case .iob:
-                cell.setActiveInsulin(isActiveContextStale ? nil : activeContext.activeInsulin)
+                if isShowingTDD {
+                    cell.setTitle(NSLocalizedString("TDD", comment: "HUD row title for TDD"))

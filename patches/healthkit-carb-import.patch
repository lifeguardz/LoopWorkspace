+//
+//  HealthKitCarbImportViewModel.swift
+//  Loop
+//
+//  Created by LoopKit Authors.
+//  Copyright © 2026 LoopKit Authors. All rights reserved.
+//
+
+import Foundation
+import HealthKit
+import LoopKit
+import Combine
+
+final class HealthKitCarbImportViewModel: ObservableObject {
+    enum State {
+        case idle
+        case loading
+        case loaded([HealthKitCarbEntry])
+        case error(Error)
+    }
+    
+    @Published var state: State = .idle
+    @Published var selectedEntryIDs: Set<String> = []
+    @Published var isImporting: Bool = false
+    
+    private let healthStore: HKHealthStore
+    private let carbStore: CarbStore
+    private let maxEntries = 100
+    private let timeRangeHours: Double = 24
+    
+    init(healthStore: HKHealthStore, carbStore: CarbStore) {
+        self.healthStore = healthStore
+        self.carbStore = carbStore
+    }
+    
+    func fetchCarbEntries() {
+        state = .loading
+        selectedEntryIDs.removeAll()
+        
+        guard let carbType = HKQuantityType.quantityType(forIdentifier: .dietaryCarbohydrates) else {
+            state = .error(NSError.healthKitNotAvailable)
+            return
+        }
+        
+        let now = Date()
+        let startDate = now.addingTimeInterval(-timeRangeHours * 60 * 60)
+        let predicate = HKQuery.predicateForSamples(withStart: startDate, end: now, options: [.strictStartDate])
+        
+        let notFromCurrentApp = NSCompoundPredicate(notPredicateWithSubpredicate: HKQuery.predicateForObjects(from: HKSource.default()))
+        let finalPredicate = NSCompoundPredicate(andPredicateWithSubpredicates: [predicate, notFromCurrentApp])
+        
+        let sortDescriptor = NSSortDescriptor(key: HKSampleSortIdentifierStartDate, ascending: false)
+        
+        let query = HKSampleQuery(
+            sampleType: carbType,
+            predicate: finalPredicate,
+            limit: maxEntries,
+            sortDescriptors: [sortDescriptor]
+        ) { [weak self] _, samples, error in
+            DispatchQueue.main.async {
+                if let error = error {
+                    self?.state = .error(error)
+                    return
+                }
+                
+                let entries = samples?.compactMap { sample -> HealthKitCarbEntry? in
+                    guard let quantitySample = sample as? HKQuantitySample else {
+                        return nil
+                    }
+                    
+                    let grams = sample.quantity.doubleValue(for: .gram())
+                    let sourceApp = sample.sourceRevision.source.name
+                    let foodType = sample.metadata?[HKMetadataKeyFoodType] as? String
+                    
+                    return HealthKitCarbEntry(
+                        id: sample.uuid.uuidString,
+                        date: sample.startDate,
+                        grams: grams,
+                        sourceApp: sourceApp,
+                        foodType: foodType,
+                        sample: quantitySample
+                    )
+                } ?? []
+                
+                self?.state = .loaded(entries)
+            }
+        }
+        
+        healthStore.execute(query)
+    }
+    
+    func toggleSelection(entryID: String) {
+        if selectedEntryIDs.contains(entryID) {
+            selectedEntryIDs.remove(entryID)
+        } else {
+            selectedEntryIDs.insert(entryID)
+        }
+    }
+    
+    func selectAll() {
+        if case .loaded(let entries) = state {
+            selectedEntryIDs = Set(entries.map { $0.id })
+        }
+    }
+    
+    func deselectAll() {
+        selectedEntryIDs.removeAll()
+    }
+    
+    func importSelected(completion: @escaping (Result<Int, Error>) -> Void) {
+        guard case .loaded(let entries) = state else {
+            completion(.failure(NSError.noEntriesFound))
+            return
+        }
+        
+        isImporting = true
+        
+        let entriesToImport = entries.filter { selectedEntryIDs.contains($0.id) }
+        
+        guard !entriesToImport.isEmpty else {
+            isImporting = false
+            completion(.success(0))
+            return
+        }
+        
+        var successCount = 0
+        var lastError: Error?
+        let dispatchGroup = DispatchGroup()
+        
+        for entry in entriesToImport {
+            dispatchGroup.enter()
+            
+            let newCarbEntry = NewCarbEntry(
+                date: entry.date,
+                quantity: HKQuantity(unit: .gram(), doubleValue: entry.grams),
+                startDate: entry.date,
+                foodType: entry.foodType,
+                absorptionTime: .hours(3)
+            )
+            
+            carbStore.addCarbEntry(newCarbEntry) { result in
+                switch result {
+                case .success:
+                    successCount += 1
+                case .failure(let error):
+                    lastError = error
+                }
+                dispatchGroup.leave()
+            }
+        }
+        
+        dispatchGroup.notify(queue: .main) { [weak self] in
+            self?.isImporting = false
+            if lastError != nil && successCount == 0 {
+                completion(.failure(lastError ?? NSError.importFailed))
+            } else {
+                completion(.success(successCount))
+            }
+        }
+    }
+    
+    var hasSelectedEntries: Bool {
+        !selectedEntryIDs.isEmpty
+    }
+    
+    var selectedCount: Int {
+        selectedEntryIDs.count
+    }
+}
+
+struct HealthKitCarbEntry: Identifiable, Equatable {
+    let id: String
+    let date: Date
+    let grams: Double
+    let sourceApp: String
+    let foodType: String?
+    let sample: HKQuantitySample
+}
+
+private extension NSError {
+    static let healthKitNotAvailable = NSError(
+        domain: "HealthKitCarbImport",
+        code: 1,
+        userInfo: [NSLocalizedDescriptionKey: "HealthKit is not available on this device"]
+    )
+    
+    static let noEntriesFound = NSError(
+        domain: "HealthKitCarbImport",
+        code: 2,
+        userInfo: [NSLocalizedDescriptionKey: "No carb entries found from external apps"]
+    )
+    
+    static let importFailed = NSError(
+        domain: "HealthKitCarbImport",
+        code: 3,
+        userInfo: [NSLocalizedDescriptionKey: "Failed to import carb entries"]
+    )
+}

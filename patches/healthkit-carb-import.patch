@@ -0,0 +1,240 @@
+//
+//  HealthKitCarbImportView.swift
+//  Loop
+//
+//  Created by LoopKit Authors.
+//  Copyright © 2026 LoopKit Authors. All rights reserved.
+//
+
+import SwiftUI
+import HealthKit
+
+struct HealthKitCarbImportView: View {
+    @Environment(\.dismiss) private var dismiss
+    @ObservedObject var viewModel: HealthKitCarbImportViewModel
+    
+    @State private var showConfirmation = false
+    @State private var importResult: Result<Int, Error>?
+    
+    private let dateFormatter: DateFormatter = {
+        let formatter = DateFormatter()
+        formatter.dateStyle = .medium
+        formatter.timeStyle = .short
+        return formatter
+    }()
+    
+    var body: some View {
+        NavigationView {
+            Group {
+                switch viewModel.state {
+                case .idle:
+                    emptyStateView
+                case .loading:
+                    loadingView
+                case .loaded(let entries):
+                    contentView(entries)
+                case .error(let error):
+                    errorView(error)
+                }
+            }
+            .navigationTitle("Import from HealthKit")
+            .navigationBarTitleDisplayMode(.inline)
+            .toolbar {
+                ToolbarItem(placement: .navigationBarLeading) {
+                    Button("Cancel") {
+                        dismiss()
+                    }
+                }
+                
+                ToolbarItem(placement: .navigationBarTrailing) {
+                    Button("Import") {
+                        showConfirmation = true
+                    }
+                    .disabled(!viewModel.hasSelectedEntries || viewModel.isImporting)
+                }
+            }
+            .onAppear {
+                viewModel.fetchCarbEntries()
+            }
+            .alert("Import Carbs", isPresented: $showConfirmation) {
+                Button("Cancel", role: .cancel) { }
+                Button("Import") {
+                    performImport()
+                }
+            } message: {
+                Text("Import \(viewModel.selectedCount) carb entr\(viewModel.selectedCount == 1 ? "y" : "ies") into Loop?")
+            }
+            .alert("Import Result", isPresented: .constant(importResult != nil)) {
+                Button("OK") {
+                    if case .success = importResult {
+                        dismiss()
+                    }
+                    importResult = nil
+                }
+            } message: {
+                if let result = importResult {
+                    switch result {
+                    case .success(let count):
+                        Text("Successfully imported \(count) carb entr\(count == 1 ? "y" : "ies").")
+                    case .failure(let error):
+                        Text("Failed to import carbs: \(error.localizedDescription)")
+                    }
+                }
+            }
+        }
+    }
+    
+    @ViewBuilder
+    private var emptyStateView: some View {
+        ContentUnavailableView {
+            Label {
+                Text("No Carb Entries Found")
+            } icon: {
+                Image(systemName: "fork.knife")
+            }
+        } description: {
+            Text("No carb entries from external apps were found in the last 24 hours.")
+        }
+    }
+    
+    @ViewBuilder
+    private var loadingView: some View {
+        ProgressView("Loading carb entries...")
+            .frame(maxWidth: .infinity, maxHeight: .infinity)
+    }
+    
+    @ViewBuilder
+    private func contentView(_ entries: [HealthKitCarbEntry]) -> some View {
+        Group {
+            if entries.isEmpty {
+                emptyStateView
+            } else {
+                List {
+                    ForEach(entries) { entry in
+                        CarbEntryRow(
+                            entry: entry,
+                            isSelected: viewModel.selectedEntryIDs.contains(entry.id),
+                            dateFormatter: dateFormatter,
+                            onToggle: {
+                                viewModel.toggleSelection(entryID: entry.id)
+                            }
+                        )
+                    }
+                }
+                .listStyle(.insetGrouped)
+                
+                if viewModel.hasSelectedEntries {
+                    selectionSummaryView
+                }
+            }
+        }
+    }
+    
+    private var selectionSummaryView: some View {
+        VStack(spacing: 8) {
+            Divider()
+            
+            HStack {
+                Text("\(viewModel.selectedCount) entr\(viewModel.selectedCount == 1 ? "y" : "ies") selected")
+                    .font(.headline)
+                
+                Spacer()
+                
+                Button("Select All") {
+                    viewModel.selectAll()
+                }
+                .font(.caption)
+                
+                Button("Clear") {
+                    viewModel.deselectAll()
+                }
+                .font(.caption)
+            }
+            .padding(.horizontal)
+            .padding(.vertical, 8)
+            .background(Color(.systemBackground))
+        }
+    }
+    
+    @ViewBuilder
+    private func errorView(_ error: Error) -> some View {
+        ContentUnavailableView {
+            Label {
+                Text("Error Loading Entries")
+            } icon: {
+                Image(systemName: "exclamationmark.triangle")
+                    .foregroundColor(.critical)
+            }
+        } description: {
+            Text(error.localizedDescription)
+        } actions: {
+            Button("Retry") {
+                viewModel.fetchCarbEntries()
+            }
+        }
+    }
+    
+    private func performImport() {
+        viewModel.importSelected { result in
+            importResult = result
+        }
+    }
+}
+
+struct CarbEntryRow: View {
+    let entry: HealthKitCarbEntry
+    let isSelected: Bool
+    let dateFormatter: DateFormatter
+    let onToggle: () -> Void
+    
+    private let gramsFormatter: NumberFormatter = {
+        let formatter = NumberFormatter()
+        formatter.numberStyle = .decimal
+        formatter.maximumFractionDigits = 0
+        return formatter
+    }()
+    
+    var body: some View {
+        HStack(spacing: 12) {
+            Toggle(isOn: Binding(
+                get: { isSelected },
+                set: { _ in onToggle() }
+            )) {
+                VStack(alignment: .leading, spacing: 4) {
+                    HStack {
+                        Text("\(gramsFormatter.string(from: NSNumber(value: entry.grams)) ?? "\(Int(entry.grams))")g")
+                            .font(.title2)
+                            .fontWeight(.semibold)
+                        
+                        Spacer()
+                    }
+                    
+                    Text(dateFormatter.string(from: entry.date))
+                        .font(.caption)
+                        .foregroundColor(.secondary)
+                    
+                    if let foodType = entry.foodType, !foodType.isEmpty {
+                        Text(foodType)
+                            .font(.caption)
+                            .foregroundColor(.secondary)
+                    }
+                    
+                    Text(entry.sourceApp)
+                        .font(.caption2)
+                        .foregroundColor(.tertiary)
+                }
+            }
+            .toggleStyle(.switch)
+        }
+        .padding(.vertical, 4)
+    }
+}
+
+#Preview {
+    HealthKitCarbImportView(
+        viewModel: HealthKitCarbImportViewModel(
+            healthStore: HKHealthStore(),
+            carbStore: CarbStore()
+        )
+    )
+}
